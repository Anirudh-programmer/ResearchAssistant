# ============================================================
# FRONTEND ENVIRONMENT VARIABLES
# Copy this file to `.env` and fill in real values.
# Never commit `.env` — only `.env.example` is tracked in git.
# ============================================================

# Clerk publishable key (safe to expose client-side).
# If left empty, the app runs in dev mode against the backend's
# auto-created dev user — see backend app/auth/dependencies.py.
VITE_CLERK_PUBLISHABLE_KEY=

# Backend API base URL. Defaults to http://localhost:8000/api/v1 if unset.
VITE_API_BASE_URL=http://localhost:8000/api/v1
