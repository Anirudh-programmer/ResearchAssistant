# ============================================================
# BACKEND ENVIRONMENT VARIABLES (Node.js version)
# Copy this file to `.env` and fill in real values.
# Never commit `.env` — only `.env.example` is tracked in git.
# ============================================================

# ---- App ----
PORT=8000
NODE_ENV=development                # development | production
APP_NAME="Investment Research Agent"
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ---- Database ----
# Neon Postgres Connection URL:
# DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"
DATABASE_URL=

# ---- Auth: Clerk ----
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=
CLERK_ISSUER=

# ---- LLM Providers ----
DEFAULT_LLM_PROVIDER=gemini          # gemini | openai | anthropic

GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ---- Research Tools ----
TAVILY_API_KEY=
NEWS_API_KEY=
FINNHUB_API_KEY=

# ---- Misc ----
SECRET_KEY=change-me-to-a-random-string
MOCK_LLM=false
