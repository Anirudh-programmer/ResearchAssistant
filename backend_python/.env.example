# ============================================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to `.env` and fill in real values.
# Never commit `.env` — only `.env.example` is tracked in git.
# ============================================================

# ---- App ----
APP_ENV=development                 # development | staging | production
APP_NAME="Investment Research Agent"
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:5173
LOG_LEVEL=INFO

# ---- Database ----
# Local dev default (no setup required): sqlite+aiosqlite:///./dev.db
# Production (Neon): postgresql+asyncpg://<user>:<password>@<host>/<db>?ssl=require
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# ---- Auth: Clerk ----
# Get these from https://dashboard.clerk.com -> API Keys
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=                     # e.g. https://<your-app>.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=                       # e.g. https://<your-app>.clerk.accounts.dev

# ---- LLM Providers ----
# Set DEFAULT_LLM_PROVIDER to "gemini" | "openai" | "anthropic"
# The backend only requires the ONE key matching the selected provider,
# but you can set multiple and switch providers without code changes.
DEFAULT_LLM_PROVIDER=gemini

GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Research Tools ----
TAVILY_API_KEY=
NEWS_API_KEY=
FINNHUB_API_KEY=

# ---- Misc ----
SECRET_KEY=change-me-to-a-random-string   # used for internal signing, not auth
